# ─── Vercel Postgres ───────────────────────────────────────
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ─── Vercel Blob / Cloudinary (upload usa Cloudinary neste projeto) ───
BLOB_READ_WRITE_TOKEN=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Autenticação ───────────────────────────────────────────
# Senha do painel /admin (use uma senha longa e exclusiva; não commite o .env)
ADMIN_PASSWORD=

# Assinatura JWT — use string aleatória longa (32+ caracteres)
# https://randomkeygen.com — CodeIgniter Encryption Keys
JWT_SECRET=

# Opcional: restringe CORS ao domínio do site (ex.: https://www.exemplo.com.br)
# Se vazio, a API usa Access-Control-Allow-Origin: *
ALLOWED_ORIGIN=
